:443 {
    tls internal

    respond /health "OK" 200

    handle /images/* {
        file_server
        root * /app/public
    }

    handle {
        reverse_proxy app:3000 {
            @error status 502
            handle_response @error {
                root * /app/services/caddy/error_pages
                rewrite * /502.html
                file_server
            }
        }
    }

    log {
        format json
    }
}